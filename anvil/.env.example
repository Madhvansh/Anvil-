# Copy to .env (gitignored) and fill in. Anvil reads these from the environment.
# Nothing here is committed — keys live only in your local .env / token cache.

# --- Pricing inputs ---
ANVIL_RISK_FREE_RATE=0.065      # annual, decimal (India ~ T-bill / MIBOR)
ANVIL_DIVIDEND_YIELD=0.012      # index dividend yield, decimal

# --- Data source selection ---
ANVIL_PRIMARY_SOURCE=demo        # demo | upstox | dhan | groww
ANVIL_STORE_PATH=anvil_store.duckdb
ANVIL_LEDGER_PATH=anvil_ledger.duckdb

# --- App database (multi-user OLTP; DuckDB above stays the research/calibration moat) ---
# Local/dev defaults to sqlite (no Docker needed). In the compose stack this is set to Postgres.
ANVIL_DATABASE_URL=sqlite+aiosqlite:///./anvil_app.db
ANVIL_SECRET_KEY=                # REQUIRED in prod: encrypts broker tokens at rest (Fernet) + signs sessions
ANVIL_DEV=false                  # true enables permissive CORS for the Vite dev server (:5173)

# --- Deploy (docker compose: app + Postgres + Caddy) ---
POSTGRES_PASSWORD=change-me      # Postgres password for the compose stack
ANVIL_DOMAIN=localhost           # real hostname for Caddy auto-TLS (e.g. anvil.duckdns.org); localhost = self-signed
# Optional coarse gate in front of the app login (see Caddyfile):
ANVIL_BASIC_USER=anvil
ANVIL_BASIC_HASH=                # caddy hash-password --plaintext 'yourpass'

# --- Upstox (PRIMARY live: chain + Greeks + IV + OI; covers NSE + BSE indices) ---
# OAuth: set key/secret/redirect, then run `anvil auth upstox`. Token dies ~03:30 IST next day.
UPSTOX_API_KEY=              # = client_id from the Upstox app (DO NOT COMMIT REAL KEYS)
UPSTOX_API_SECRET=           # = client_secret (keep real values only in .env, which is gitignored)
UPSTOX_REDIRECT_URI=http://127.0.0.1:8765/callback   # must match the app's registered URI
UPSTOX_ACCESS_TOKEN=             # optional: paste a token directly to skip the OAuth dance

# --- Dhan (fallback chain) ---
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# --- Zerodha Kite (positions → risk book; READ ONLY) ---
# Run `anvil auth kite` (uses api_key + a request_token from the login redirect).
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=
KITE_MCP_URL=https://mcp.kite.trade/mcp

# --- Groww (chain + positions + gated/dry-run execution) ---
# Run `anvil auth groww`. Prefer the TOTP seed (non-expiring) if your account uses it.
GROWW_API_KEY=
GROWW_API_SECRET=
GROWW_TOTP_SEED=
GROWW_MCP_URL=https://mcp.groww.in/mcp

# --- Grounded AI copilot (optional; falls back to deterministic narration if unset) ---
ANTHROPIC_API_KEY=
ANVIL_AGENT_MODEL=claude-opus-4-8

# --- Feature flags ---
ASSISTED_EXECUTION=true
TRADING_AUTOMATION=false          # KEEP OFF. Live auto-trading is a separate, gated decision.

# --- Paper-trading simulation (personal money-making mock loop; gated, real exec stays OFF above) ---
PAPER_TRADING=true                # gates the whole /api/paper surface + the strategy/realtime engine
PAPER_SELLER_MODE=true            # allow naked short premium structures (owner choice; risk-governed)
PAPER_ALLOW_EVENT_RISK=false      # allow opening trades into imminent expiry/event risk
# Aggressive sizing profile (per-trade risk and exposure caps)
PAPER_STARTING_CAPITAL=1000000    # paper account starting capital (INR)
PAPER_RISK_FRACTION=0.05          # max modeled loss per trade as a fraction of equity (<=5%)
PAPER_KELLY_FRACTION=0.55         # fractional Kelly applied on top of the risk cap
PAPER_MAX_EXPOSURE_PCT=0.40       # gross exposure cap (fraction of equity)
PAPER_MAX_LOTS_PER_UNDERLYING=20
PAPER_MAX_OPEN_POSITIONS=12
PAPER_MIN_CONVICTION=0.55         # candidates below this become "no-trade"
PAPER_VRP_RATIO=0.85              # realized/implied move ratio (variance risk premium edge basis)
# Risk governor
PAPER_MAX_DRAWDOWN_PCT=0.15       # account drawdown kill-switch (halts new entries, can flatten)
PAPER_MAX_DAILY_LOSS_PCT=0.06     # daily loss limit
PAPER_MIN_LIQUIDITY_OI=50000      # reject contracts thinner than this OI
PAPER_MAX_SPREAD_PCT=0.06         # reject legs whose (ask-bid)/mid exceeds this
# Cost model (headline knobs; full STT/exchange/GST/stamp/SEBI schedule in anvil/paper/costs.py)
PAPER_SLIPPAGE_BPS=5              # half-spread fallback in bps of mid when no quotes
PAPER_BROKERAGE_PER_ORDER=20      # flat brokerage per order leg (INR)
